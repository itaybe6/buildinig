# שם הלקוח (Default) — לעולם אל תשנה ידנית את BUSINESS_ID לאחר יצירת רשומה ב-DB

# Multi-tenant identifier (UUID של ה-tenant ב-public.tenants)
BUSINESS_ID=00000000-0000-0000-0000-000000000000

# Mobile (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_BUSINESS_ID=00000000-0000-0000-0000-000000000000

# Web (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_BUSINESS_ID=00000000-0000-0000-0000-000000000000
